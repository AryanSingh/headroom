# Cutctx proxy configuration
# Copy this file to .env.local and fill in real values before running.
# See docs/configuration.md for the full reference.
#
# NOTE: Use .env.local for local development (not committed).
# Use .env in production after proper configuration.

# ── Neo4j Graph Database ──────────────────────────────────────────────────
# Used by memory backends (direct_mem0, mem0).
# Format: bolt://host:port or neo4j://host:port
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Alternative: Combined Neo4j auth string (parsed as neo4j/<password>)
# NEO4J_AUTH=neo4j/REPLACE_WITH_STRONG_PASSWORD

# ── Core Proxy ────────────────────────────────────────────────────────────
# Bind address for the FastAPI server.
CUTCTX_PROXY_HOST=0.0.0.0
CUTCTX_PROXY_PORT=8787

# Comma-separated list of upstream provider API keys.
# At least one is required for live traffic.
CUTCTX_UPSTREAM_OPENAI_API_KEY=
CUTCTX_UPSTREAM_ANTHROPIC_API_KEY=
CUTCTX_UPSTREAM_GOOGLE_API_KEY=
CUTCTX_UPSTREAM_BEDROCK_API_KEY=

# Default upstream when no per-request model is specified.
CUTCTX_DEFAULT_PROVIDER=anthropic

# ── Admin API Key ─────────────────────────────────────────────────────────
# Gates /dashboard, /stats, /stats-reset, /transformations/feed endpoints.
# When set, requests must include Authorization: Bearer <key> header.
# REQUIRED in production. Auto-generates a random key if unset (dev only).
CUTCTX_ADMIN_API_KEY=

# Failed admin/SSO authentication attempts permitted per client IP each minute.
# Set to 0 only to disable this brute-force guard.
CUTCTX_ADMIN_AUTH_FAILURES_PER_MINUTE=10

# ── Audit Log (HMAC tamper-evident chain) ──────────────────────────────────
# REQUIRED. The proxy refuses to start without this in production.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
CUTCTX_AUDIT_SECRET_KEY=

# For local dev only — opt-in to a process-unique random key (no persistence).
# CUTCTX_ALLOW_DEV_AUDIT_KEY=1

# Audit database path (EE only)
# CUTCTX_AUDIT_DB_PATH=~/.cutctx/audit.db

# ── Anti-Debug Guard (Security) ────────────────────────────────────────────
# Prevents execution under debugger attachment (for EE runtime).
# Set to 1 to allow debuggers in local/dev environments only.
# The flag is ignored if the process is not bound to loopback (127.0.0.1).
# WARNING: Never set to 1 in production — it will be rejected if non-loopback.
CUTCTX_ALLOW_DEBUG=0

# ── License (EE) ──────────────────────────────────────────────────────────
# License key for enterprise features.
CUTCTX_LICENSE_KEY=

# License Ed25519 keys (only needed if running EE signer/verifier in
# air-gapped mode or building residency attestations).
CUTCTX_LICENSE_KID=
CUTCTX_LICENSE_PRIVATE_KEY=
CUTCTX_LICENSE_PUBLIC_KEY=

# Policy key for signing/verifying policies (EE)
# CUTCTX_POLICY_KID=
# CUTCTX_POLICY_PRIVATE_KEY=

# Entitlement tier (auto-detected from license if set, or manual override).
# Values: "builder" (free), "team", "business", "enterprise".
CUTCTX_ENTITLEMENT_TIER=

# ── SSO (OIDC) ────────────────────────────────────────────────────────────
# Optional. When unset, only admin-key auth works.
CUTCTX_SSO_DISCOVERY_URL=
CUTCTX_SSO_JWKS_URI=
CUTCTX_SSO_ISSUER=
CUTCTX_SSO_AUDIENCE=

# SSO provider type: "oidc" (default) or "okta"
# CUTCTX_SSO_PROVIDER_TYPE=oidc

# Comma-separated list of scopes required for SSO-authenticated requests.
CUTCTX_SSO_REQUIRED_SCOPES=

# JSON object mapping claim paths to roles.
# Example: {"groups": "viewer", "email": "viewer", "admin": "admin"}
CUTCTX_SSO_ROLE_MAPPING=

# Default role for SSO-authenticated users without explicit role mapping.
CUTCTX_SSO_DEFAULT_ROLE=viewer

# SSO timeouts and cache settings (seconds)
# CUTCTX_SSO_HTTP_TIMEOUT=10
# CUTCTX_SSO_CLOCK_SKEW_TOLERANCE=60
# CUTCTX_SSO_JWKS_CACHE_TTL=3600

# SSO introspection (token validation via introspection endpoint)
# CUTCTX_SSO_INTROSPECTION_URL=
# CUTCTX_SSO_INTROSPECTION_CLIENT_ID=
# CUTCTX_SSO_INTROSPECTION_CLIENT_SECRET=

# ── Webhooks (outbound event delivery) ─────────────────────────────────────
# Master switch; defaults to enabled.
CUTCTX_WEBHOOKS_ENABLED=true
# Comma-separated default subscriptions (set by env for simple setups).
CUTCTX_WEBHOOK_URL=

# ── Model Routing (Per-model routing policy) ───────────────────────────────
# Disabled by default. JSON, e.g.
# {"enabled": true, "routes": [{"match_model": "claude-opus-4-5",
#  "use_model": "claude-sonnet-4-5", "expected_savings_pct": 50}]}
CUTCTX_MODEL_ROUTING=
# Optional named preset for productized routing behavior. Examples:
#   economy                -> aggressive downgrade policy
#   subrequest-haiku       -> internal helper/subrequest routing
#   codex-gpt54mini-high   -> keep GPT-5 for heavy Codex work, route low-
#                             complexity turns to gpt-5.4-mini with high reasoning
#   codex-opencode-slim    -> compatibility alias for codex-gpt54mini-high
# CUTCTX_MODEL_ROUTING_PRESET=

# Provider-neutral orchestration control plane. Project config defaults to
# .cutctx/orchestration.json; encrypted state defaults to ~/.cutctx/orchestration.
# CUTCTX_ORCHESTRATION_CONFIG=/path/to/orchestration.json
# CUTCTX_ORCHESTRATION_DIR=~/.cutctx/orchestration
# Optional externally managed Fernet key; omit to create a local mode-0600 key.
# CUTCTX_ORCHESTRATION_MASTER_KEY=
# Development diagnostics only; this raw endpoint bypasses the canonical pipeline.
# CUTCTX_ORCHESTRATION_DIRECT_EXECUTION=false

# ── Savings canary (Codex / GPT-5.x) ───────────────────────────────────────
# Deterministic 10% treatment arms for mutable-tail compression, tool/API
# slimming, and model routing; the remaining 70% is the existing control.
CUTCTX_SAVINGS_CANARY_ENABLED=0
CUTCTX_SAVINGS_CANARY_PERCENT=10
# Hard stop when quality or provider-cache value regresses by more than 1%.
CUTCTX_SAVINGS_CANARY_REGRESSION_LIMIT=0.01
CUTCTX_SAVINGS_CANARY_MIN_SAMPLES=100
# Set a deployment-stable secret so assignment remains sticky across restarts.
# CUTCTX_SAVINGS_CANARY_SALT=
# Durable restart-safe experiment state (created with mode 0600).
# CUTCTX_SAVINGS_CANARY_PATH=~/.cutctx/savings_canary.json
# Development only: production promotion excludes request-ID-only identities.
CUTCTX_SAVINGS_CANARY_ALLOW_NON_STICKY=0
# Optional automatic quality feedback from the before/after evaluation harness.
# CUTCTX_SAVINGS_CANARY_FEEDBACK_URL=http://127.0.0.1:8787
# CUTCTX_SAVINGS_CANARY_EVAL_ARM=model_routing
# CUTCTX_SAVINGS_CANARY_EVALUATOR=coding-eval-v1
# CUTCTX_SAVINGS_CANARY_EVAL_RUN_ID=release-candidate-1

# ── Trial / Entitlements ────────────────────────────────────────────────────
# Set to 0 to disable trial enforcement.
CUTCTX_TRIAL_ENFORCEMENT=1

# PitchToShip base URL for license API calls (default: https://pitchtoship.com).
# Used by cutctx_ee/billing/ for license validation and usage reporting.
PITCHTOSHIP_URL=https://pitchtoship.com

# Alternate override for the license API endpoint specifically (optional).
# CUTCTX_LICENSE_API_URL=https://pitchtoship.com

# ── Air-gap / Offline Mode ─────────────────────────────────────────────────
# When 1, the proxy expects to run with no external network access.
# See docs/air-gap-deployment.md for the full checklist.
CUTCTX_OFFLINE_MODE=0

# Required when CUTCTX_OFFLINE_MODE=1. HMAC secret for license validation.
CUTCTX_LICENSE_HMAC_SECRET=

# ── Firewall (LLM prompt-injection + PII scanner) ──────────────────────────
# Off by default for backwards compatibility. Recommended: enable in
# any deployment that handles untrusted input.
CUTCTX_FIREWALL_ENABLED=0
CUTCTX_FIREWALL_BLOCK_PII=1
CUTCTX_FIREWALL_BLOCK_INJECTION=1
CUTCTX_FIREWALL_BLOCK_JAILBREAK=1
# Set to 1 only to disable streaming PII redaction (it is enabled by default).
CUTCTX_FIREWALL_NO_REDACT_STREAMING=0

# ── Memory Backends ────────────────────────────────────────────────────────
# Local SQLite is the default; set to use a remote backend.
CUTCTX_MEMORY_BACKEND=local
CUTCTX_MEMORY_DB_PATH=~/.cutctx/memory.db

# Qdrant (vector search / semantic memory)
CUTCTX_QDRANT_URL=
CUTCTX_QDRANT_API_KEY=
# CUTCTX_QDRANT_HOST=localhost
# CUTCTX_QDRANT_PORT=6333

# Neo4j (graph storage / relationships)
CUTCTX_NEO4J_URL=bolt://localhost:7687

# Team sync for shared memory (optional)
CUTCTX_TEAM_SYNC_ENABLED=false
# CUTCTX_MEMORY_SERVICE_URL=

# ── Spend Ledger / Billing (EE) ────────────────────────────────────────────
CUTCTX_SPEND_LEDGER_DB=~/.cutctx/spend_ledger.db
CUTCTX_POLICY_DB=~/.cutctx/policy.db

# PitchToShip/Razorpay webhook signing secret.
# Cutctx billing is managed by PitchToShip (pitchtoship.com) via Razorpay.
# Obtain from the PitchToShip dashboard. PRODUCTION MUST set this;
# the proxy refuses to start without it when BILLING_STRICT_MODE=1.
CUTCTX_RAZORPAY_WEBHOOK_SECRET=
CUTCTX_BILLING_STRICT_MODE=1

# ── RBAC (Role-Based Access Control) ────────────────────────────────────────
# Database for RBAC assignments (EE)
# CUTCTX_RBAC_DB_PATH=~/.cutctx/rbac.db

# ── Org Database (EE) ──────────────────────────────────────────────────────
# CUTCTX_ORG_DB_PATH=~/.cutctx/org.db

# ── SCIM (System for Cross-domain Identity Management) ──────────────────────
# CUTCTX_SCIM_DB_PATH=~/.cutctx/scim.db

# ── Compression & CCR (Compress-Cache-Retrieve) ───────────────────────────
# Keep ML text fallback off by default for predictable latency. Set to 1 to
# allow ContentRouter to use Kompress for unstructured text/mixed fallback.
CUTCTX_ENABLE_KOMPRESS=0
# Feature-flagged simple hosted compression API: POST /v1/hosted/compress.
CUTCTX_HOSTED_COMPRESSION_ENABLED=0
# Optional API key for hosted compression endpoint.
# CUTCTX_HOSTED_COMPRESSION_API_KEY=
# Backend for compression store: sqlite, redis, etc.
CUTCTX_CCR_BACKEND=sqlite
# CUTCTX_REDIS_URL=redis://localhost:6379/0
# CUTCTX_CCR_TENANT_PREFIX=

# ── Telemetry ──────────────────────────────────────────────────────────────
# Set to 0 to disable the local beacon. Telemetry is opt-out and
# anonymous; see docs/observability.md.
CUTCTX_TELEMETRY_ENABLED=1
# CUTCTX_TELEMETRY_DISABLED=1  # Alternative disable flag

# ── Logging ────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR.
CUTCTX_LOG_LEVEL=INFO
# CUTCTX_LOG_FORMAT=text          # "text" (default) or "json" for structured JSON logging

# Set to 1 to log full request/response messages (PII risk — dev only).
CUTCTX_LOG_MESSAGES=0

# ── Binary/Extension Management ────────────────────────────────────────────
# CUTCTX_BINARIES_OFFLINE=0      # Offline mode for binaries
# CUTCTX_BINARIES_MIRROR=        # Custom mirror URL
# CUTCTX_BINARIES_CACHE=         # Cache directory override

# ── MCP / Integration ──────────────────────────────────────────────────────
# Enable read operations in MCP server
CUTCTX_MCP_READ=off

# Proxy URL for external access (used by integrations)
CUTCTX_PROXY_URL=http://127.0.0.1:8787

# ── Max Request Body Size ──────────────────────────────────────────────────
# Default: 50 MB
# CUTCTX_MAX_BODY_MB=50

# ── Tool Result Interception ───────────────────────────────────────────────
# Enable tool result interception (ast-grep outline, etc.)
# CUTCTX_INTERCEPT_ENABLED=0

# ── Episodic Memory ────────────────────────────────────────────────────────
# Cross-session memory extraction and injection
# CUTCTX_EPISODIC_MEMORY_ENABLED=0
# CUTCTX_EPISODIC_IDLE_TIMEOUT_SECONDS=300
# CUTCTX_EPISODIC_EXTRACTION_MODEL=claude-3-haiku-20240307

# ── Traffic Learning ───────────────────────────────────────────────────────
# Learn patterns from agent traffic
# CUTCTX_TRAFFIC_LEARNING_ENABLED=0
# CUTCTX_TRAFFIC_LEARNING_MIN_EVIDENCE=5

# ── Retention Policies (EE) ────────────────────────────────────────────────
# CUTCTX_RETENTION_AUDIT_DAYS=90
# CUTCTX_RETENTION_LOGS_DAYS=30
