# Cutctx proxy configuration
# Copy this file to .env and fill in real values before running in production.
# See docs/configuration.md for the full reference.

# ── Database (for memory backends) ────────────────────────────────────────
# IMPORTANT: Change NEO4J_AUTH before deploying — default credentials are insecure.
NEO4J_AUTH=neo4j/CHANGEME

# ── Core proxy ───────────────────────────────────────────────────────────
# Bind address for the FastAPI server.
CUTCTX_PROXY_HOST=0.0.0.0
CUTCTX_PROXY_PORT=8787

# Comma-separated list of upstream provider API keys.
# At least one is required for live traffic.
CUTCTX_UPSTREAM_OPENAI_API_KEY=
CUTCTX_UPSTREAM_ANTHROPIC_API_KEY=
CUTCTX_UPSTREAM_GOOGLE_API_KEY=
CUTCTX_UPSTREAM_BEDROCK_API_KEY=

# Default upstream when no per-request model is specified.
CUTCTX_DEFAULT_PROVIDER=anthropic

# ── Admin auth ───────────────────────────────────────────────────────────
# REQUIRED in production. Auto-generates a random key if unset and prints
# it to stderr (NOT to the Python logger, to avoid leaking via
# centralized log aggregation).
CUTCTX_ADMIN_API_KEY=

# ── Audit log (HMAC tamper-evident chain) ────────────────────────────────
# REQUIRED. The proxy refuses to start without this in production.
# Generate with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
CUTCTX_AUDIT_SECRET_KEY=

# For local dev only — opt-in to a process-unique random key.
# HEADROOM_ALLOW_DEV_AUDIT_KEY=1

# ── License (EE) ─────────────────────────────────────────────────────────
# License key for enterprise features.
CUTCTX_LICENSE_KEY=

# License Ed25519 keys (only needed if running the EE signer/verifier in
# air-gapped mode or building residency attestations).
CUTCTX_LICENSE_KID=
CUTCTX_LICENSE_PRIVATE_KEY=
CUTCTX_LICENSE_PUBLIC_KEY=

# ── SSO (OIDC) ───────────────────────────────────────────────────────────
# Optional. When unset, only admin-key auth works.
CUTCTX_SSO_DISCOVERY_URL=
CUTCTX_SSO_JWKS_URI=
CUTCTX_SSO_ISSUER=
CUTCTX_SSO_AUDIENCE=
# Comma-separated list of scopes required for SSO-authenticated requests.
CUTCTX_SSO_REQUIRED_SCOPES=
# JSON object mapping claim paths to roles, e.g.
# {"groups": "viewer", "email": "viewer", "admin": "admin"}
CUTCTX_SSO_ROLE_MAPPING=
CUTCTX_SSO_DEFAULT_ROLE=viewer

# ── Webhooks (outbound event delivery) ──────────────────────────────────
# Master switch; defaults to enabled.
CUTCTX_WEBHOOKS_ENABLED=true
# Comma-separated default subscriptions (set by env for simple setups).
CUTCTX_WEBHOOK_URL=

# ── Model routing (Blocker-5 moat-b1 source) ────────────────────────────
# Disabled by default. JSON, e.g.
# {"enabled": true, "routes": [{"match_model": "claude-opus-4-5",
#  "use_model": "claude-sonnet-4-5", "expected_savings_pct": 50}]}
CUTCTX_MODEL_ROUTING=

# ── Trial / entitlements ─────────────────────────────────────────────────
# Set to 0 to disable trial enforcement.
CUTCTX_TRIAL_ENFORCEMENT=1
# PitchToShip endpoint for license validation (network).
CUTCTX_LICENSE_VALIDATION_URL=

# ── Air-gap / offline mode ───────────────────────────────────────────────
# When 1, the proxy expects to run with no external network access. See
# docs/air-gap-deployment.md for the full checklist.
HEADROOM_OFFLINE_MODE=0
# Required when HEADROOM_OFFLINE_MODE=1.
HEADROOM_LICENSE_HMAC_SECRET=

# ── Firewall (LLM prompt-injection + PII scanner) ────────────────────────
# Off by default for backwards compatibility. Recommended: enable in
# any deployment that handles untrusted input.
CUTCTX_FIREWALL_ENABLED=0
CUTCTX_FIREWALL_BLOCK_PII=1
CUTCTX_FIREWALL_BLOCK_INJECTION=1
CUTCTX_FIREWALL_BLOCK_JAILBREAK=1
CUTCTX_FIREWALL_REDACT_STREAMING=1

# ── Memory backends ─────────────────────────────────────────────────────
# Local SQLite is the default; set to use a remote backend.
CUTCTX_MEMORY_BACKEND=local
CUTCTX_MEMORY_DB_PATH=~/.headroom/memory.db
# Qdrant (vector)
CUTCTX_QDRANT_URL=
CUTCTX_QDRANT_API_KEY=
# Neo4j (graph) — see NEO4J_AUTH above.
CUTCTX_NEO4J_URL=bolt://localhost:7687

# ── Spend ledger / billing (EE) ─────────────────────────────────────────
CUTCTX_SPEND_LEDGER_DB=~/.headroom/spend_ledger.db
CUTCTX_POLICY_DB=~/.headroom/policy.db
# Stripe webhook signing secret. PRODUCTION MUST set this; the proxy
# refuses to start without it when STRICT_MODE=1.
CUTCTX_STRIPE_WEBHOOK_SECRET=
CUTCTX_BILLING_STRICT_MODE=1

# ── Telemetry ───────────────────────────────────────────────────────────
# Set to 0 to disable the local beacon. Telemetry is opt-out and
# anonymous; see docs/observability.md.
CUTCTX_TELEMETRY_ENABLED=1

# ── Logging ─────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR.
CUTCTX_LOG_LEVEL=INFO
# Set to 1 to log full request/response messages (PII risk — dev only).
CUTCTX_LOG_MESSAGES=0
