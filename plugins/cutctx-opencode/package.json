{
  "name": "cutctx-opencode",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CutCtx opencode plugin: auto-compresses tool outputs, history, and streams.",
  "main": "dist/cutctx.js",
  "exports": "./dist/cutctx.js",
  "scripts": {
    "build": "esbuild cutctx.ts --bundle --platform=node --format=esm --outfile=dist/cutctx.js --external:@opencode-ai/plugin",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.0.0",
    "cutctx-ai": "file:../../sdk/typescript"
  },
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "vite": "^6.4.3",
    "vitest": "^3.2.6",
    "@types/node": "^20.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
