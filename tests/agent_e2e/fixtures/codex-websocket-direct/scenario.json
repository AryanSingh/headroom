{
  "schema_version": 1,
  "id": "codex-websocket-direct",
  "client": "codex",
  "client_version": "0.145.0-alpha.18",
  "tags": ["oauth-auth", "websocket", "ws-reconnect", "tools", "stream-true", "store-false"],
  "runtimes": ["python"],
  "unsupported_runtimes": [
    {
      "runtime": "native",
      "reason": "Native subscription WebSocket routing is not implemented.",
      "tracking_issue": "CUTCTX-NATIVE-RESPONSES-SUBSCRIPTION"
    }
  ],
  "steps": [
    {
      "action": "request",
      "transport": "websocket",
      "path": "/v1/responses",
      "headers_fixture": "headers.json",
      "body_fixtures": ["frame.json", "resume-frame.json"],
      "upstream_scripts": ["success-ws.json", "resume-success-ws.json"]
    }
  ],
  "assertions": {
    "required_body_values": {"$.store": false, "$.stream": true},
    "preserved_paths": ["$.model", "$.input", "$.tools"],
    "terminal_event": "response.completed"
  }
}
